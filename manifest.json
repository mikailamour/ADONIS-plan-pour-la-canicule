<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
<title>ADONIS · Plan Canicule</title>

<!-- PWA : installation sur l'écran d'accueil -->
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#1F3B57">
<meta name="background-color" content="#F6F2E9">
<link rel="icon" type="image/png" href="icons/favicon-32.png">
<link rel="apple-touch-icon" href="icons/icon-180.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Plan Canicule">
<meta name="mobile-web-app-capable" content="yes">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#1F3B57;
    --navy-deep:#152A3F;
    --sand:#F6F2E9;
    --sand-deep:#EDE6D6;
    --card:#FFFFFF;
    --ink:#20262B;
    --ink-soft:#5B6770;
    --line:#E3DCC9;
    --v1:#3C8C5B; --v1-soft:#E3F0E6;
    --v2:#DDB02B; --v2-soft:#FBF1D9;
    --v3:#D9622B; --v3-soft:#FBE9DD;
    --v4:#C2362B; --v4-soft:#F8DEDB;
    --radius:18px;
    --radius-sm:12px;
    --shadow: 0 1px 2px rgba(31,59,87,.06), 0 8px 24px -8px rgba(31,59,87,.14);
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0; padding:0;}
  body{
    font-family:'Inter',-apple-system,Segoe UI,sans-serif;
    background:var(--sand);
    color:var(--ink);
    display:flex; justify-content:center;
    min-height:100vh;
  }
  .display{font-family:'Archivo','Inter',sans-serif;}
  .mono{font-family:'IBM Plex Mono',monospace;}

  /* ---------- App shell ---------- */
  #app{
    width:100%; max-width:480px;
    min-height:100vh;
    background:var(--sand);
    display:flex; flex-direction:column;
    position:relative;
    box-shadow: var(--shadow);
  }
  header.appbar{
    background:var(--navy);
    color:#fff;
    padding:18px 18px 16px;
    position:sticky; top:0; z-index:30;
    box-shadow:0 6px 16px -8px rgba(0,0,0,.35);
  }
  header.appbar .row{display:flex; align-items:center; justify-content:space-between; gap:10px;}
  header.appbar .brand{display:flex; flex-direction:column; line-height:1.05;}
  header.appbar .brand b{font-family:'Archivo'; font-weight:800; font-size:18px; letter-spacing:.02em;}
  header.appbar .brand span{font-size:11px; color:#C9D6E2; letter-spacing:.06em; text-transform:uppercase;}
  .level-pill{
    display:flex; align-items:center; gap:6px;
    padding:6px 10px 6px 8px; border-radius:999px;
    font-size:12px; font-weight:700; color:#fff;
    border:1px solid rgba(255,255,255,.25);
    white-space:nowrap;
  }
  .dot{width:8px; height:8px; border-radius:50%; flex:none;}

  main{flex:1; overflow-y:auto; padding:16px 16px 110px; -webkit-overflow-scrolling:touch;}
  .view{display:none; animation:fade .22s ease;}
  .view.active{display:block;}
  @keyframes fade{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  /* ---------- Bottom nav ---------- */
  nav.tabbar{
    position:sticky; bottom:0; z-index:30;
    display:grid; grid-template-columns:repeat(5,1fr);
    background:#fff;
    border-top:1px solid var(--line);
    padding:6px 4px calc(8px + env(safe-area-inset-bottom));
  }
  nav.tabbar button{
    background:none; border:none; cursor:pointer;
    display:flex; flex-direction:column; align-items:center; gap:3px;
    color:var(--ink-soft); font-size:10.5px; font-weight:600;
    padding:6px 2px; border-radius:10px;
    font-family:'Inter';
  }
  nav.tabbar button.alert-tab{color:var(--v4);}
  nav.tabbar button.active{color:var(--navy); background:var(--sand-deep);}
  nav.tabbar button.active.alert-tab{color:var(--v4);}
  nav.tabbar svg{width:21px; height:21px;}

  /* ---------- Generic components ---------- */
  .card{
    background:var(--card); border:1px solid var(--line);
    border-radius:var(--radius); padding:16px;
    box-shadow:var(--shadow); margin-bottom:14px;
  }
  h1.page-title{font-family:'Archivo'; font-weight:800; font-size:21px; color:var(--navy); margin:4px 0 4px;}
  p.page-sub{color:var(--ink-soft); font-size:13.5px; margin:0 0 16px; line-height:1.45;}
  h2.sec-title{font-family:'Archivo'; font-weight:700; font-size:14.5px; color:var(--navy); margin:0 0 10px; display:flex; align-items:center; gap:8px;}
  .eyebrow{font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--v3);}

  .btn{
    display:flex; align-items:center; justify-content:center; gap:8px;
    border:none; cursor:pointer; border-radius:var(--radius-sm);
    font-weight:700; font-size:14px; font-family:'Inter'; padding:13px 16px;
    width:100%;
  }
  .btn-primary{background:var(--navy); color:#fff;}
  .btn-alert{background:var(--v4); color:#fff;}
  .btn-ghost{background:var(--sand-deep); color:var(--navy);}
  .btn-outline{background:#fff; color:var(--navy); border:1.5px solid var(--line);}
  .btn-sm{padding:9px 12px; font-size:13px; width:auto;}
  .btn[disabled]{opacity:.45; pointer-events:none;}

  .pill-row{display:flex; gap:8px; overflow-x:auto; padding-bottom:2px; margin-bottom:14px; scrollbar-width:none;}
  .pill-row::-webkit-scrollbar{display:none;}
  .pill{
    flex:none; padding:9px 14px; border-radius:999px; font-size:12.5px; font-weight:700;
    background:#fff; border:1.5px solid var(--line); color:var(--ink-soft); cursor:pointer;
  }
  .pill.active{background:var(--navy); border-color:var(--navy); color:#fff;}

  textarea,input[type=text],input[type=number],select{
    width:100%; border:1.5px solid var(--line); border-radius:10px; padding:10px 12px;
    font-family:'Inter'; font-size:14px; color:var(--ink); background:#fff;
  }
  textarea{resize:vertical; min-height:54px;}
  label.field-label{font-size:12px; font-weight:700; color:var(--ink-soft); display:block; margin:0 0 5px;}
  .field{margin-bottom:12px;}

  .seg{display:grid; grid-template-columns:repeat(3,1fr); gap:6px;}
  .seg button{
    border:1.5px solid var(--line); background:#fff; border-radius:10px;
    padding:9px 4px; font-size:11.5px; font-weight:700; color:var(--ink-soft); cursor:pointer; line-height:1.25;
  }
  .seg button.sel-0.active{background:var(--v1-soft); border-color:var(--v1); color:#1f5c39;}
  .seg button.sel-1.active{background:var(--v2-soft); border-color:var(--v2); color:#7a5c10;}
  .seg button.sel-2.active{background:var(--v4-soft); border-color:var(--v4); color:var(--v4);}

  .badge{display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:999px; font-size:11.5px; font-weight:700;}
  .row-between{display:flex; align-items:center; justify-content:space-between; gap:10px;}
  .divider{height:1px; background:var(--line); margin:12px 0;}
  .empty{text-align:center; color:var(--ink-soft); font-size:13px; padding:18px 8px;}
  .empty b{display:block; color:var(--ink); font-size:14px; margin-bottom:4px;}

  .check-row{display:flex; align-items:flex-start; gap:11px; padding:11px 2px; border-bottom:1px solid var(--line);}
  .check-row:last-child{border-bottom:none;}
  .checkbox{
    width:22px; height:22px; border-radius:7px; border:2px solid var(--line); flex:none; margin-top:1px;
    display:flex; align-items:center; justify-content:center; cursor:pointer; background:#fff;
  }
  .checkbox.checked{background:var(--v1); border-color:var(--v1);}
  .checkbox svg{width:13px; height:13px; stroke:#fff; display:none;}
  .checkbox.checked svg{display:block;}
  .check-row span{font-size:14px; line-height:1.4; padding-top:1px;}
  .check-row.done span{color:var(--ink-soft); text-decoration:line-through;}

  table.mini{width:100%; border-collapse:collapse; font-size:12.5px;}
  table.mini th{text-align:left; color:#fff; background:var(--navy); padding:8px 8px; font-size:11px; font-weight:700;}
  table.mini td{padding:8px 8px; border-bottom:1px solid var(--line);}
  table.mini tr:nth-child(even) td{background:var(--sand-deep);}
  .icon-btn{background:none; border:none; cursor:pointer; color:var(--ink-soft); padding:4px;}
  .icon-btn:active{color:var(--v4);}

  .step-card{border-left:5px solid var(--navy); background:var(--sand-deep); border-radius:12px; padding:13px 14px; margin-bottom:0;}
  .step-card.danger{border-left-color:var(--v4); background:var(--v4-soft);}
  .step-card.warn{border-left-color:var(--v3); background:var(--v3-soft);}
  .step-card b{color:var(--navy); font-family:'Archivo'; font-size:12.5px; display:block; margin-bottom:3px; letter-spacing:.03em;}
  .step-card.danger b{color:var(--v4);}
  .step-card.warn b{color:var(--v3);}
  .step-card p{margin:0; font-size:13.5px; line-height:1.45;}
  .arrow{text-align:center; color:var(--v3); font-size:16px; padding:4px 0;}

  details.acc{border:1px solid var(--line); border-radius:12px; margin-bottom:10px; background:#fff; overflow:hidden;}
  details.acc summary{list-style:none; cursor:pointer; padding:13px 14px; font-weight:700; font-size:13.5px; color:var(--navy); display:flex; align-items:center; justify-content:between; gap:10px;}
  details.acc summary::-webkit-details-marker{display:none;}
  details.acc summary::after{content:'+'; margin-left:auto; font-size:18px; color:var(--ink-soft); font-weight:400;}
  details.acc[open] summary::after{content:'–';}
  details.acc .acc-body{padding:0 14px 14px; font-size:13.5px; color:var(--ink); line-height:1.55;}
  details.acc .acc-body ul{margin:6px 0; padding-left:18px;}
  details.acc .acc-body li{margin-bottom:5px;}

  .msg-card{border:1px dashed var(--line); border-radius:12px; padding:12px 13px; background:var(--sand-deep); font-size:13px; line-height:1.5; color:var(--ink); margin-bottom:10px;}
  .msg-head{display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;}
  .msg-head b{font-size:12.5px; color:var(--navy);}
  .copy-btn{display:flex; align-items:center; gap:5px; background:#fff; border:1.5px solid var(--line); color:var(--navy); font-size:11.5px; font-weight:700; padding:6px 10px; border-radius:999px; cursor:pointer;}
  .copy-btn svg{width:12px; height:12px;}
  .toast{
    position:fixed; bottom:96px; left:50%; transform:translateX(-50%) translateY(10px);
    background:var(--navy); color:#fff; padding:10px 18px; border-radius:999px; font-size:13px; font-weight:600;
    box-shadow:var(--shadow); opacity:0; transition:opacity .2s, transform .2s; pointer-events:none; z-index:90; white-space:nowrap;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}

  /* ---------- Gauge ---------- */
  .gauge-wrap{display:flex; flex-direction:column; align-items:center; padding:6px 0 2px;}
  .gauge-readout{display:flex; flex-direction:column; align-items:center; margin-top:-58px;}
  .gauge-readout .lvl{font-family:'Archivo'; font-weight:800; font-size:34px; line-height:1;}
  .gauge-readout .lbl{font-size:12.5px; font-weight:700; color:var(--ink-soft); margin-top:2px; text-align:center; max-width:220px;}
  .needle{transition:transform .5s cubic-bezier(.34,1.56,.64,1);}
  .level-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-top:18px;}
  .level-opt{border-radius:12px; padding:10px 4px; text-align:center; cursor:pointer; border:1.5px solid var(--line); background:#fff;}
  .level-opt b{display:block; font-family:'Archivo'; font-size:18px; font-weight:800;}
  .level-opt span{display:block; font-size:9.5px; font-weight:700; color:var(--ink-soft); margin-top:1px; line-height:1.2;}
  .level-opt.sel{border-width:2px;}

  .score-ring{
    width:96px; height:96px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    flex:none; border:6px solid var(--line); background:#fff;
  }
  .score-ring .n{font-family:'IBM Plex Mono'; font-weight:600; font-size:26px;}
  .score-ring .d{font-size:10px; color:var(--ink-soft); margin-top:-2px;}

  .qa-grid{display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px;}
  .qa{
    background:#fff; border:1px solid var(--line); border-radius:14px; padding:14px 12px;
    display:flex; flex-direction:column; gap:8px; cursor:pointer; text-align:left;
  }
  .qa svg{width:20px; height:20px; color:var(--navy);}
  .qa b{font-size:13px; font-family:'Archivo'; color:var(--ink); line-height:1.25;}
  .qa.danger{background:var(--v4-soft); border-color:#eac4bf;}
  .qa.danger svg{color:var(--v4);}
  .qa.danger b{color:var(--v4);}
</style>
</head>
<body>

<div id="app">

  <header class="appbar">
    <div class="row">
      <div class="brand"><b>ADONIS</b><span>Plan Canicule</span></div>
      <div class="level-pill" id="headerPill" style="background:rgba(255,255,255,.12)">
        <span class="dot" id="headerDot"></span><span id="headerPillText">Niveau —</span>
      </div>
    </div>
  </header>

  <main id="main"></main>

  <div class="toast" id="toast"></div>

  <nav class="tabbar" id="tabbar">
    <button data-tab="accueil" class="active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>
      Accueil
    </button>
    <button data-tab="ivt">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><circle cx="12" cy="16" r="5"/><path d="M9 16h6"/></svg>
      IVT
    </button>
    <button data-tab="fiches">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3 8-8"/><path d="M20 12v6a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h9"/></svg>
      Fiches
    </button>
    <button data-tab="alerte" class="alert-tab">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M10.3 3.9L2.7 17a2 2 0 001.7 3h15.2a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/><path d="M12 17h.01"/></svg>
      Alerte
    </button>
    <button data-tab="plus">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l2.5 2.5"/></svg>
      Référentiel
    </button>
  </nav>
</div>

<script>
/* =====================================================================
   ADONIS · Plan Canicule — Application mobile
   ===================================================================== */

const LEVEL_COLOR = { 1:'#3C8C5B', 2:'#DDB02B', 3:'#D9622B', 4:'#C2362B' };
const LEVEL_SOFT  = { 1:'#E3F0E6', 2:'#FBF1D9', 3:'#FBE9DD', 4:'#F8DEDB' };
const LEVEL_NAME  = { 1:'Veille saisonnière', 2:'Avertissement chaleur', 3:'Alerte canicule', 4:'Mobilisation maximale' };
const LEVEL_SHORT = { 1:'Veille', 2:'Avertissement', 3:'Alerte', 4:'Mobil. max.' };
const LEVEL_DESC  = {
  1:'Vigilance standard. Hydratation rappelée à chaque visite.',
  2:'Vérifiez la grille IVT des bénéficiaires fragiles. Contrôle systématique de l’hydratation.',
  3:'Horaires adaptés aux heures fraîches. Surveillance renforcée et compte rendu obligatoire au coordinateur après chaque visite.',
  4:'Priorisez les bénéficiaires à IVT élevé. Passages biquotidiens si nécessaire. Point quotidien avec la cellule de crise.',
};

const CRITERIA = [
  { key:'age',        label:'Âge',                  options:['Moins de 65 ans','65 à 80 ans','Plus de 80 ans'] },
  { key:'autonomie',  label:'Autonomie',             options:['Autonome','Aide partielle','Dépendance importante'] },
  { key:'pathologie', label:'Pathologie à risque',   options:['Aucune','Une identifiée','Plusieurs / traitement à risque'] },
  { key:'isolement',  label:'Isolement',             options:['Entourage quotidien','Entourage occasionnel','Isolement complet'] },
  { key:'logement',   label:'Logement',              options:['Climatisé / ventilé','Ventilation correcte','Mal ventilé / exposé'] },
];

const CHECKLIST_ITEMS = [
  "Logement aéré le matin puis fermé / volets clos aux heures chaudes",
  "Boisson proposée et accessible à portée de main",
  "Température ambiante de la pièce de vie vérifiée si possible",
  "Vêtements légers, absence de surcouverture",
  "Aucun signe de confusion, malaise ou propos incohérents observé",
  "Score IVT du bénéficiaire connu et pris en compte",
  "Fiche hydratation et fiche de surveillance renseignées",
];

const SURVEILLANCE_INDICATORS = [
  { key:'conscience',  label:'État de conscience',  opts:['Orienté, répond normalement','Ralenti, fatigue inhabituelle','Confusion, propos incohérents'] },
  { key:'temperature', label:'Température ressentie', opts:['Normale','Chaude au toucher','Très chaude, peau sèche'] },
  { key:'hydratation', label:'Hydratation',          opts:['Boit normalement','Boit peu, bouche sèche','Refuse de boire'] },
  { key:'mobilite',    label:'Comportement / mobilité', opts:['Habituel','Vertiges, faiblesse','Chute, convulsions'] },
];

const AUDIT_QUESTIONS = [
  "La cartographie des bénéficiaires à risque est-elle à jour ?",
  "La grille IVT est-elle renseignée pour tous les bénéficiaires à risque ?",
  "L'ensemble des intervenants a-t-il suivi la formation annuelle ?",
  "Le logigramme décisionnel est-il affiché et connu des équipes ?",
  "Les fiches terrain sont-elles correctement renseignées et archivées ?",
  "Les indicateurs qualité sont-ils suivis et analysés ?",
  "La cellule de crise s'est-elle réunie conformément aux modalités prévues ?",
];

/* ---------------------------------------------------------------- */
/* Stockage local (persistant sur l'appareil, fonctionne hors ligne) */
/* ---------------------------------------------------------------- */
function sGet(key, fallback) {
  try {
    const v = localStorage.getItem(key);
    return v !== null ? JSON.parse(v) : fallback;
  } catch (e) { return fallback; }
}
function sSet(key, value) {
  try { localStorage.setItem(key, JSON.stringify(value)); }
  catch (e) { console.error('Échec de l’enregistrement local', key, e); }
}

function todayStr() {
  const d = new Date();
  return d.toISOString().slice(0,10);
}

/* ---------------------------------------------------------------- */
/* Application state                                                */
/* ---------------------------------------------------------------- */
const state = {
  tab: 'accueil',
  level: 1,
  ivtList: [],
  ivtForm: { editingId:null, name:'', age:0, autonomie:0, pathologie:0, isolement:0, logement:0 },
  fiches: { date: todayStr(), checklist:{}, hydratation:[], surveillance:{}, transmission:[] },
  fichesTab: 'checklist',
  contacts: { coordinateur:'', astreinte:'', medecin:'' },
  audit: {},
};

let booted = false;

async function loadState() {
  state.level   = await sGet('vigilance-level', 1);
  state.ivtList = await sGet('ivt-list', []);
  const fiches  = await sGet('fiches-data', null);
  if (fiches && fiches.date === todayStr()) {
    state.fiches = fiches;
  } else {
    state.fiches = { date: todayStr(), checklist:{}, hydratation:[], surveillance:{}, transmission:[] };
    await sSet('fiches-data', state.fiches);
  }
  state.contacts = await sGet('contacts', { coordinateur:'', astreinte:'', medecin:'' });
  state.audit    = await sGet('audit-checklist', {});
  booted = true;
}

/* ---------------------------------------------------------------- */
/* Utilities                                                         */
/* ---------------------------------------------------------------- */
function uid() { return Math.random().toString(36).slice(2,9); }
function esc(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

function ivtScore(item) {
  return (item.age||0)+(item.autonomie||0)+(item.pathologie||0)+(item.isolement||0)+(item.logement||0);
}
function ivtInterpret(score) {
  if (score <= 2) return { label:'Vulnérabilité faible',   color:LEVEL_COLOR[1], freq:'Visite habituelle, vigilance standard.' };
  if (score <= 5) return { label:'Vulnérabilité modérée',  color:LEVEL_COLOR[2], freq:'Contrôle de l’hydratation à chaque passage.' };
  if (score <= 8) return { label:'Vulnérabilité élevée',   color:LEVEL_COLOR[3], freq:'Passage renforcé en niveau 3-4, contact médecin si doute.' };
  return            { label:'Vulnérabilité majeure',       color:LEVEL_COLOR[4], freq:'Surveillance rapprochée quotidienne dès le niveau 2.' };
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(()=>t.classList.remove('show'), 1800);
}

function copyText(text) {
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(()=>toast('Message copié')).catch(()=>toast('Copie indisponible'));
  } else {
    toast('Copie indisponible sur cet appareil');
  }
}

/* ---------------------------------------------------------------- */
/* Header                                                            */
/* ---------------------------------------------------------------- */
function renderHeader() {
  document.getElementById('headerDot').style.background = LEVEL_COLOR[state.level];
  document.getElementById('headerPillText').textContent = `Niveau ${state.level} · ${LEVEL_SHORT[state.level]}`;
}

/* ---------------------------------------------------------------- */
/* Gauge (signature element)                                         */
/* ---------------------------------------------------------------- */
function describeArc(cx, cy, r, startDeg, endDeg) {
  const toXY = (deg) => {
    const rad = (deg-90) * Math.PI/180;
    return [cx + r*Math.cos(rad), cy + r*Math.sin(rad)];
  };
  const [x1,y1] = toXY(startDeg);
  const [x2,y2] = toXY(endDeg);
  const large = (endDeg-startDeg) > 180 ? 1 : 0;
  return `M ${x1} ${y1} A ${r} ${r} 0 ${large} 1 ${x2} ${y2}`;
}

function gaugeSVG() {
  const cx=130, cy=120, r=98;
  const bounds = [-90,-45,0,45,90];
  let arcs = '';
  for (let i=0;i<4;i++) {
    arcs += `<path d="${describeArc(cx,cy,r,bounds[i],bounds[i+1])}" stroke="${LEVEL_COLOR[i+1]}" stroke-width="16" fill="none" stroke-linecap="round" opacity="${state.level===i+1?1:0.32}"/>`;
  }
  const centers = { 1:-67.5, 2:-22.5, 3:22.5, 4:67.5 };
  const needleAngle = centers[state.level];
  // ticks
  let ticks='';
  [1,2,3,4].forEach(l=>{
    const a=(centers[l]-90)*Math.PI/180;
    const x1=cx+ (r-13)*Math.cos(a), y1=cy+(r-13)*Math.sin(a);
    const x2=cx+ (r+13)*Math.cos(a), y2=cy+(r+13)*Math.sin(a);
    ticks += `<text x="${x1<cx?x1-2:x1+2}" y="${y1+4}" font-size="10" font-weight="700" fill="#9aa3a8" text-anchor="middle" font-family="IBM Plex Mono">${l}</text>`;
  });
  return `
  <svg width="260" height="148" viewBox="0 0 260 148">
    ${arcs}
    ${ticks}
    <g class="needle" style="transform:rotate(${needleAngle}deg); transform-origin:${cx}px ${cy}px;">
      <line x1="${cx}" y1="${cy}" x2="${cx}" y2="${cy-r+22}" stroke="${LEVEL_COLOR[state.level]}" stroke-width="4" stroke-linecap="round"/>
      <circle cx="${cx}" cy="${cy}" r="8" fill="${LEVEL_COLOR[state.level]}"/>
      <circle cx="${cx}" cy="${cy}" r="3.2" fill="#fff"/>
    </g>
  </svg>`;
}

async function setLevel(l) {
  state.level = l;
  await sSet('vigilance-level', l);
  renderHeader();
  render();
}

