  return `<div class="pill-row">${tabs.map(([k,l])=>`<div class="pill ${state.fichesTab===k?'active':''}" data-fichetab="${k}">${l}</div>`).join('')}</div>`;
}

function viewChecklist() {
  const done = CHECKLIST_ITEMS.filter((_,i)=>state.fiches.checklist[i]).length;
  return `
    <div class="card">
      <div class="row-between" style="margin-bottom:8px;">
        <h2 class="sec-title" style="margin:0;">Check-list auxiliaire</h2>
        <span class="badge mono" style="background:var(--sand-deep); color:var(--navy);">${done}/${CHECKLIST_ITEMS.length}</span>
      </div>
