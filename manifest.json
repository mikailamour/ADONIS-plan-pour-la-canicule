      </div>
      <div class="row-between">
        <span style="font-size:13.5px;">Dont vulnérabilité élevée / majeure</span>
        <span class="mono" style="font-weight:700; color:${nbCritiques>0?LEVEL_COLOR[3]:'var(--ink)'}">${nbCritiques}</span>
