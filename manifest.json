      <button class="qa" data-goto="ivt"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="16" r="5"/><path d="M12 2v8"/></svg><b>Calculer un score IVT</b></button>
      <button class="qa danger" data-goto="alerte"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4"/><path d="M10.3 3.9L2.7 17a2 2 0 001.7 3h15.2a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/><path d="M12 17h.01"/></svg><b>Signe d'alerte chez un bénéficiaire</b></button>
      <button class="qa" data-goto="plus"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg><b>Modèles de messages</b></button>
    </div>

