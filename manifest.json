        <table class="mini"><tbody>
          <tr><td><strong>Avril</strong></td><td>Rappel des consignes, mise à jour IVT</td></tr>
          <tr><td><strong>Mai</strong></td><td>Atelier reconnaissance des signes d'alerte</td></tr>
          <tr><td><strong>Juin</strong></td><td>Simulation d'une canicule extrême</td></tr>
          <tr><td><strong>Septembre</strong></td><td>Retour d'expérience de fin de saison</td></tr>
        </tbody></table>
      </div>
    </details>

    <details class="acc">
      <summary>Indicateurs qualité</summary>
      <div class="acc-body">
        <table class="mini"><tbody>
          <tr><td>Grilles IVT à jour</td><td><strong>Cible 100 %</strong></td></tr>
          <tr><td>Complétude des fiches terrain</td><td><strong>Cible ≥ 95 %</strong></td></tr>
          <tr><td>Délai moyen de remontée d'alerte</td><td><strong>Cible ≤ 30 min</strong></td></tr>
          <tr><td>Visites non réalisées en tension</td><td><strong>Cible ≤ 2 %</strong></td></tr>
        </tbody></table>
      </div>
    </details>

    <details class="acc">
      <summary>Audit interne — Auto-évaluation (${auditDone}/${AUDIT_QUESTIONS.length})</summary>
      <div class="acc-body">
        ${AUDIT_QUESTIONS.map((q,i)=>`
          <div class="check-row ${state.audit[i]?'done':''}">
            <div class="checkbox ${state.audit[i]?'checked':''}" data-auditidx="${i}">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span>${q}</span>
          </div>`).join('')}
      </div>
    </details>

    <details class="acc">
      <summary>À propos</summary>
      <div class="acc-body">
        <p>PC-ADONIS-CANICULE-01 — v1.0. Application compagnon du Pack d'Excellence HAS, Plan Canicule ADONIS. Les données saisies sont conservées sur cet appareil.</p>
        <button class="btn btn-outline" id="resetAll">Réinitialiser les données de l'application</button>
      </div>
    </details>
  `;
}

/* ---------------------------------------------------------------- */
/* Router / render                                                   */
/* ---------------------------------------------------------------- */
function render() {
  const main = document.getElementById('main');
  if (state.tab === 'accueil') main.innerHTML = viewAccueil();
  else if (state.tab === 'ivt') main.innerHTML = viewIVT();
  else if (state.tab === 'fiches') main.innerHTML = viewFiches();
  else if (state.tab === 'alerte') main.innerHTML = viewAlerte();
  else main.innerHTML = viewPlus();

  document.querySelectorAll('#tabbar button').forEach(b => b.classList.toggle('active', b.dataset.tab===state.tab));
  attachEvents();
  main.scrollTop = main._keepScroll ? main._keepScroll : 0;
  main._keepScroll = 0;
}

function goto(tab, extra) {
  state.tab = tab;
  if (extra && extra.fichesTab) state.fichesTab = extra.fichesTab;
  render();
}

/* ---------------------------------------------------------------- */
/* Event wiring                                                      */
/* ---------------------------------------------------------------- */
function attachEvents() {
  const main = document.getElementById('main');

  main.querySelectorAll('[data-goto]').forEach(el => {
    el.addEventListener('click', () => goto(el.dataset.goto, { fichesTab: el.dataset.fichetab }));
  });
  main.querySelectorAll('[data-setlevel]').forEach(el => {
    el.addEventListener('click', () => setLevel(parseInt(el.dataset.setlevel)));
  });

  /* ---- IVT form ---- */
  const nameInput = document.getElementById('ivtName');
  if (nameInput) nameInput.addEventListener('input', e => { state.ivtForm.name = e.target.value; });

  main.querySelectorAll('[data-critkey]').forEach(group => {
    group.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        state.ivtForm[group.dataset.critkey] = parseInt(btn.dataset.val);
        main._keepScroll = main.scrollTop;
        render();
      });
    });
  });
  const ivtSave = document.getElementById('ivtSave');
  if (ivtSave) ivtSave.addEventListener('click', async () => {
    const f = state.ivtForm;
    if (f.editingId) {
      const idx = state.ivtList.findIndex(i=>i.id===f.editingId);
      if (idx>-1) state.ivtList[idx] = { ...f, id:f.editingId };
    } else {
      state.ivtList.push({ ...f, id:uid() });
    }
    await sSet('ivt-list', state.ivtList);
    state.ivtForm = { editingId:null, name:'', age:0, autonomie:0, pathologie:0, isolement:0, logement:0 };
    toast('Bénéficiaire enregistré');
    render();
  });
  const ivtCancel = document.getElementById('ivtCancel');
  if (ivtCancel) ivtCancel.addEventListener('click', () => {
    state.ivtForm = { editingId:null, name:'', age:0, autonomie:0, pathologie:0, isolement:0, logement:0 };
    render();
  });
  main.querySelectorAll('[data-editivt]').forEach(el => {
    el.addEventListener('click', () => {
      const item = state.ivtList.find(i=>i.id===el.dataset.editivt);
      if (item) { state.ivtForm = { ...item, editingId:item.id }; main._keepScroll = 0; render(); window.scrollTo(0,0); }
    });
  });
  main.querySelectorAll('[data-delivt]').forEach(el => {
    el.addEventListener('click', async (ev) => {
      ev.stopPropagation();
      state.ivtList = state.ivtList.filter(i=>i.id!==el.dataset.delivt);
      await sSet('ivt-list', state.ivtList);
      toast('Bénéficiaire supprimé');
      render();
    });
  });

  /* ---- Fiches pills ---- */
  main.querySelectorAll('[data-fichetab]').forEach(el => {
    if (el.dataset.goto) return;
    el.addEventListener('click', () => { state.fichesTab = el.dataset.fichetab; render(); });
  });

  /* ---- Checklist ---- */
  main.querySelectorAll('[data-checkidx]').forEach(el => {
    el.addEventListener('click', async () => {
      const i = el.dataset.checkidx;
      state.fiches.checklist[i] = !state.fiches.checklist[i];
      await sSet('fiches-data', state.fiches);
      render();
    });
  });

  /* ---- Hydratation ---- */
  const hydAdd = document.getElementById('hydAdd');
  if (hydAdd) hydAdd.addEventListener('click', async () => {
    const heure = document.getElementById('hydHeure').value.trim() || nowHHMM();
    const boisson = document.getElementById('hydBoisson').value;
    const qte = document.getElementById('hydQte').value || '0';
    const obs = document.getElementById('hydObs').value.trim();
    state.fiches.hydratation.push({ id:uid(), heure, boisson, qte, obs });
    await sSet('fiches-data', state.fiches);
    toast('Prise ajoutée');
    render();
  });
  main.querySelectorAll('[data-delhyd]').forEach(el => {
    el.addEventListener('click', async () => {
      state.fiches.hydratation = state.fiches.hydratation.filter(r=>r.id!==el.dataset.delhyd);
      await sSet('fiches-data', state.fiches);
      render();
    });
  });

  /* ---- Surveillance ---- */
  main.querySelectorAll('[data-survkey]').forEach(group => {
    group.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', async () => {
        state.fiches.surveillance[group.dataset.survkey] = parseInt(btn.dataset.val);
        await sSet('fiches-data', state.fiches);
        render();
      });
    });
  });

  /* ---- Transmission ---- */
  const trAdd = document.getElementById('trAdd');
  if (trAdd) trAdd.addEventListener('click', async () => {
    const benef = document.getElementById('trBenef').value.trim();
    const obs = document.getElementById('trObs').value.trim();
    const action = document.getElementById('trAction').value.trim();
    const dest = document.getElementById('trDest').value.trim();
    if (!obs) { toast('Merci de décrire l’observation'); return; }
    state.fiches.transmission.push({ id:uid(), heure:nowHHMM(), benef, obs, action, dest });
    await sSet('fiches-data', state.fiches);
    toast('Transmission enregistrée');
    render();
  });
  main.querySelectorAll('[data-deltr]').forEach(el => {
    el.addEventListener('click', async () => {
      state.fiches.transmission = state.fiches.transmission.filter(r=>r.id!==el.dataset.deltr);
      await sSet('fiches-data', state.fiches);
      render();
    });
  });

  /* ---- Référentiel ---- */
  main.querySelectorAll('[data-copymsg]').forEach(el => {
    el.addEventListener('click', () => copyText(MESSAGES[parseInt(el.dataset.copymsg)].body));
  });
  main.querySelectorAll('[data-auditidx]').forEach(el => {
    el.addEventListener('click', async () => {
      const i = el.dataset.auditidx;
      state.audit[i] = !state.audit[i];
      await sSet('audit-checklist', state.audit);
      render();
    });
  });
  const contactsSave = document.getElementById('contactsSave');
  if (contactsSave) contactsSave.addEventListener('click', async () => {
    state.contacts = {
      coordinateur: document.getElementById('cCoord').value.trim(),
      astreinte: document.getElementById('cAstreinte').value.trim(),
      medecin: document.getElementById('cMedecin').value.trim(),
    };
    await sSet('contacts', state.contacts);
    toast('Contacts enregistrés');
  });
  const resetAll = document.getElementById('resetAll');
  if (resetAll) resetAll.addEventListener('click', async () => {
    if (!confirm('Réinitialiser toutes les données enregistrées sur cet appareil ?')) return;
    for (const k of ['vigilance-level','ivt-list','fiches-data','contacts','audit-checklist']) {
      try { localStorage.removeItem(k); } catch(e) {}
    }
    state.level = 1; state.ivtList = []; state.contacts = { coordinateur:'', astreinte:'', medecin:'' }; state.audit = {};
    state.fiches = { date: todayStr(), checklist:{}, hydratation:[], surveillance:{}, transmission:[] };
    renderHeader();
    toast('Données réinitialisées');
    render();
  });
}

/* ---------------------------------------------------------------- */
/* Tab bar + boot                                                    */
/* ---------------------------------------------------------------- */
document.getElementById('tabbar').addEventListener('click', (e) => {
  const btn = e.target.closest('button[data-tab]');
  if (!btn) return;
  state.tab = btn.dataset.tab;
  render();
});

(async function boot() {
  await loadState();
  renderHeader();
  render();
})();

/* ---------------------------------------------------------------- */
/* Service worker — fonctionnement hors connexion                    */
/* ---------------------------------------------------------------- */
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').catch(err => console.warn('SW non disponible :', err));
  });
}

</script>
</body>
</html>
