function viewFiches() {
  const body = state.fichesTab==='checklist'? viewChecklist()
    : state.fichesTab==='hydratation'? viewHydratation()
    : state.fichesTab==='surveillance'? viewSurveillance()
    : viewTransmission();
  return `
    <h1 class="page-title">Fiches terrain</h1>
    <p class="page-sub">Supports à renseigner à chaque visite. Les données du jour sont conservées sur cet appareil.</p>
    ${fichesPills()}
    ${body}
  `;
}

