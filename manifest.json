function ivtFormHTML() {
  const f = state.ivtForm;
  return `
    <div class="card">
      <div class="row-between" style="margin-bottom:10px;">
        <h2 class="sec-title" style="margin:0;">${f.editingId? 'Modifier le bénéficiaire' : 'Nouveau bénéficiaire'}</h2>
        ${f.editingId? `<button class="copy-btn" id="ivtCancel">Annuler</button>` : ''}
      </div>
      <div class="field">
        <label class="field-label">Nom / repère bénéficiaire</label>
        <input type="text" id="ivtName" placeholder="Ex. Mme R. — secteur Nord" value="${esc(f.name)}">
      </div>
      ${CRITERIA.map(c => `
        <div class="field">
          <label class="field-label">${c.label}</label>
          <div class="seg" data-critkey="${c.key}">
            ${c.options.map((o,i)=>`<button class="sel-${i} ${f[c.key]===i?'active':''}" data-val="${i}">${o}</button>`).join('')}
          </div>
        </div>`).join('')}
      <div class="row-between" style="margin:12px 0;">
        ${(() => { const sc = ivtScore(f); const it = ivtInterpret(sc); return `
          <div class="score-ring" style="border-color:${it.color}">
            <div style="text-align:center;"><div class="n">${sc}</div><div class="d">/10</div></div>
          </div>
          <div style="flex:1; padding-left:14px;">
            <div style="font-weight:700; color:${it.color}; font-size:13.5px;">${it.label}</div>
            <div style="font-size:12px; color:var(--ink-soft); margin-top:3px; line-height:1.4;">${it.freq}</div>
          </div>`; })()}
      </div>
      <button class="btn btn-primary" id="ivtSave">${f.editingId? 'Enregistrer les modifications' : 'Enregistrer le bénéficiaire'}</button>
    </div>
  `;
}

function viewIVT() {
  const sorted = [...state.ivtList].sort((a,b)=>ivtScore(b)-ivtScore(a));
  return `
    <h1 class="page-title">Indice de Vulnérabilité Thermique</h1>
    <p class="page-sub">Cotez chaque bénéficiaire à risque pour prioriser les passages selon le niveau de vigilance en cours.</p>
    ${ivtFormHTML()}
    <h2 class="sec-title" style="margin-top:4px;">Bénéficiaires enregistrés (${sorted.length})</h2>
    <div class="card" style="padding:6px 14px;">
      ${sorted.length===0 ? `<div class="empty"><b>Aucun bénéficiaire enregistré</b>Ajoutez une fiche ci-dessus pour commencer le suivi.</div>` :
        sorted.map(item => {
          const sc = ivtScore(item); const it = ivtInterpret(sc);
          return `
          <div class="check-row" style="align-items:center;">
            <div class="score-ring" style="width:46px; height:46px; border-width:4px; border-color:${it.color};">
              <span class="mono" style="font-size:14px; font-weight:700;">${sc}</span>
            </div>
            <div style="flex:1; padding-left:4px;" data-editivt="${item.id}">
